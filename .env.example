# ============================================================
# Fashion Shop API — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# Spring Profile (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Database (local dev)
DB_USERNAME=postgres
DB_PASSWORD=password

# Database (production - Neon.tech)
# Get from: https://neon.tech → Project Settings → Connection Details
DATABASE_URL=jdbc:postgresql://ep-xxx.neon.tech/fashionshop?sslmode=require
DATABASE_USERNAME=
DATABASE_PASSWORD=

# JWT (min 32 characters, generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-key-that-is-at-least-32-chars-long

